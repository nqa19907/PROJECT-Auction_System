<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="auction_system.client.controllers.DangBanController">

    <!-- ===== SIDEBAR ===== -->
    <VBox minWidth="200" prefWidth="200"
          style="-fx-background-color: #1A2744; -fx-padding: 16 0 16 0;">

        <Label style="-fx-text-fill: #5a6a8a; -fx-font-size: 10; -fx-font-weight: bold;
                      -fx-padding: 16 20 6 20;"
               text="TỔNG QUAN" />
        <Button maxWidth="1.7976931348623157E308"
                onAction="#handleGoDashboard"
                style="-fx-background-color: transparent; -fx-text-fill: #c0cce0;
                       -fx-font-size: 13; -fx-padding: 11 20; -fx-cursor: hand;
                       -fx-border-width: 0; -fx-alignment: CENTER_LEFT;"
                text="  Dashboard" />
        <Button maxWidth="1.7976931348623157E308"
                style="-fx-background-color: #253159; -fx-text-fill: #C9A84C;
                       -fx-font-size: 13; -fx-font-weight: bold;
                       -fx-padding: 11 17; -fx-cursor: hand;
                       -fx-border-color: #C9A84C; -fx-border-width: 0 0 0 3;
                       -fx-border-radius: 0; -fx-background-radius: 0;
                       -fx-alignment: CENTER_LEFT;"
                text="  + Đăng bán mới" />

        <Label style="-fx-text-fill: #5a6a8a; -fx-font-size: 10; -fx-font-weight: bold;
                      -fx-padding: 16 20 6 20;"
               text="QUẢN LÝ" />
        <Button maxWidth="1.7976931348623157E308"
                style="-fx-background-color: transparent; -fx-text-fill: #c0cce0;
                       -fx-font-size: 13; -fx-padding: 11 20; -fx-cursor: hand;
                       -fx-border-width: 0; -fx-alignment: CENTER_LEFT;"
                text="  Phiên của tôi" />
        <Button maxWidth="1.7976931348623157E308"
                style="-fx-background-color: transparent; -fx-text-fill: #c0cce0;
                       -fx-font-size: 13; -fx-padding: 11 20; -fx-cursor: hand;
                       -fx-border-width: 0; -fx-alignment: CENTER_LEFT;"
                text="  Đấu giá của tôi" />
        <Button maxWidth="1.7976931348623157E308"
                style="-fx-background-color: transparent; -fx-text-fill: #c0cce0;
                       -fx-font-size: 13; -fx-padding: 11 20; -fx-cursor: hand;
                       -fx-border-width: 0; -fx-alignment: CENTER_LEFT;"
                text="  Lịch sử" />

        <Label style="-fx-text-fill: #5a6a8a; -fx-font-size: 10; -fx-font-weight: bold;
                      -fx-padding: 16 20 6 20;"
               text="TÀI KHOẢN" />
        <Button maxWidth="1.7976931348623157E308"
                style="-fx-background-color: transparent; -fx-text-fill: #c0cce0;
                       -fx-font-size: 13; -fx-padding: 11 20; -fx-cursor: hand;
                       -fx-border-width: 0; -fx-alignment: CENTER_LEFT;"
                text="  Hồ sơ" />
        <Button maxWidth="1.7976931348623157E308"
                style="-fx-background-color: transparent; -fx-text-fill: #c0cce0;
                       -fx-font-size: 13; -fx-padding: 11 20; -fx-cursor: hand;
                       -fx-border-width: 0; -fx-alignment: CENTER_LEFT;"
                text="  Cài đặt" />
    </VBox>

    <!-- ===== MAIN FORM ===== -->
    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                style="-fx-background-color: #F7F4EF; -fx-background: #F7F4EF;"
                HBox.hgrow="ALWAYS">
        <content>
            <VBox spacing="16"
                  style="-fx-background-color: #F7F4EF; -fx-padding: 24 32 32 32;">

                <!-- Breadcrumb -->
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label style="-fx-font-size: 12; -fx-text-fill: #888; -fx-cursor: hand;"
                           text="Dashboard"  />
                    <Label style="-fx-font-size: 12; -fx-text-fill: #aaa;" text="›" />
                    <Label style="-fx-font-size: 12; -fx-text-fill: #C9A84C; -fx-font-weight: bold;"
                           text="Đăng bán mới" />
                </HBox>

                <!-- Page title -->
                <Label style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1A2744;"
                       text="Tạo phiên đấu giá mới" />

                <!-- Step indicator -->
                <HBox alignment="CENTER_LEFT" spacing="0">
                    <HBox alignment="CENTER" spacing="8">
                        <Label style="-fx-background-color: #1A2744; -fx-text-fill: #C9A84C;
                                      -fx-font-size: 11; -fx-font-weight: bold;
                                      -fx-background-radius: 50; -fx-border-color: #C9A84C;
                                      -fx-border-radius: 50; -fx-border-width: 1.5;
                                      -fx-min-width: 24; -fx-min-height: 24;
                                      -fx-alignment: CENTER;"
                               text="1" />
                        <Label style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #1A2744;"
                               text="Thông tin cơ bản" />
                    </HBox>
                    <Separator prefWidth="40" style="-fx-padding: 0 8;" />
                    <HBox alignment="CENTER" spacing="8">
                        <Label style="-fx-background-color: #e8e8e8; -fx-text-fill: #aaa;
                                      -fx-font-size: 11; -fx-font-weight: bold;
                                      -fx-background-radius: 50;
                                      -fx-min-width: 24; -fx-min-height: 24;
                                      -fx-alignment: CENTER;"
                               text="2" />
                        <Label style="-fx-font-size: 12; -fx-text-fill: #aaa;"
                               text="Thời gian &amp; Giá" />
                    </HBox>
                    <Separator prefWidth="40" style="-fx-padding: 0 8;" />
                    <HBox alignment="CENTER" spacing="8">
                        <Label style="-fx-background-color: #e8e8e8; -fx-text-fill: #aaa;
                                      -fx-font-size: 11; -fx-font-weight: bold;
                                      -fx-background-radius: 50;
                                      -fx-min-width: 24; -fx-min-height: 24;
                                      -fx-alignment: CENTER;"
                               text="3" />
                        <Label style="-fx-font-size: 12; -fx-text-fill: #aaa;" text="Xác nhận" />
                    </HBox>
                </HBox>

                <!-- ===== CARD 1: Thông tin tài sản ===== -->
                <VBox spacing="16"
                      style="-fx-background-color: white; -fx-background-radius: 12;
                             -fx-border-color: #e8e8e8; -fx-border-radius: 12;
                             -fx-border-width: 1; -fx-padding: 20 24 24 24;">

                    <HBox alignment="CENTER_LEFT"
                          style="-fx-border-color: #f0f0f0; -fx-border-width: 0 0 1 0; -fx-padding: 0 0 12 0;">
                        <Label style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1A2744;"
                               text="Thông tin tài sản" />
                    </HBox>

                    <!-- Tên tài sản -->
                    <VBox spacing="6">
                        <HBox spacing="2">
                            <Label style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #555;"
                                   text="Tên tài sản" />
                            <Label style="-fx-font-size: 12; -fx-text-fill: #E24B4A;" text="*" />
                        </HBox>
                        <TextField fx:id="fieldTenTaiSan"
                                   promptText="VD: Đồng hồ Rolex Submariner Date 2004"
                                   style="-fx-font-size: 13; -fx-background-radius: 8;
                                          -fx-border-radius: 8; -fx-border-color: #ddd;
                                          -fx-border-width: 1; -fx-padding: 8 12;" />
                    </VBox>

                    <!-- Danh mục + Tình trạng -->
                    <GridPane hgap="16">
                        <columnConstraints>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="50" />
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="50" />
                        </columnConstraints>
                        <VBox spacing="6" GridPane.columnIndex="0">
                            <HBox spacing="2">
                                <Label style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #555;"
                                       text="Danh mục" />
                                <Label style="-fx-font-size: 12; -fx-text-fill: #E24B4A;" text="*" />
                            </HBox>
                            <ComboBox fx:id="comboDanhMuc"
                                      maxWidth="1.7976931348623157E308"
                                      promptText="Chọn danh mục..."
                                      style="-fx-font-size: 13; -fx-background-radius: 8;" />
                        </VBox>
                        <VBox spacing="6" GridPane.columnIndex="1">
                            <Label style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #555;"
                                   text="Tình trạng" />
                            <ComboBox fx:id="comboTinhTrang"
                                      maxWidth="1.7976931348623157E308"
                                      promptText="Chọn tình trạng..."
                                      style="-fx-font-size: 13; -fx-background-radius: 8;" />
                        </VBox>
                    </GridPane>

                    <!-- Mô tả -->
                    <VBox spacing="6">
                        <HBox spacing="2">
                            <Label style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #555;"
                                   text="Mô tả sản phẩm" />
                            <Label style="-fx-font-size: 12; -fx-text-fill: #E24B4A;" text="*" />
                        </HBox>
                        <TextArea fx:id="fieldMoTa"
                                  prefHeight="100"
                                  promptText="Mô tả nguồn gốc, tình trạng, đặc điểm nổi bật của tài sản..."
                                  wrapText="true"
                                  style="-fx-font-size: 13; -fx-background-radius: 8;
                                         -fx-border-radius: 8; -fx-border-color: #ddd;
                                         -fx-border-width: 1; -fx-padding: 8 12;" />
                    </VBox>
                </VBox>

                <!-- ===== CARD 2: Thời gian & Giá ===== -->
                <VBox spacing="16"
                      style="-fx-background-color: white; -fx-background-radius: 12;
                             -fx-border-color: #e8e8e8; -fx-border-radius: 12;
                             -fx-border-width: 1; -fx-padding: 20 24 24 24;">

                    <HBox alignment="CENTER_LEFT"
                          style="-fx-border-color: #f0f0f0; -fx-border-width: 0 0 1 0; -fx-padding: 0 0 12 0;">
                        <Label style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1A2744;"
                               text="Thời gian &amp; Giá khởi điểm" />
                    </HBox>

                    <!-- Thời gian -->
                    <GridPane hgap="16">
                        <columnConstraints>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="50" />
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="50" />
                        </columnConstraints>
                        <VBox spacing="6" GridPane.columnIndex="0">
                            <HBox spacing="2">
                                <Label style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #555;"
                                       text="Thời gian bắt đầu" />
                                <Label style="-fx-font-size: 12; -fx-text-fill: #E24B4A;" text="*" />
                            </HBox>
                            <TextField fx:id="fieldThoiGianBatDau"
                                       promptText="dd/MM/yyyy HH:mm"
                                       style="-fx-font-size: 13; -fx-background-radius: 8;
                                              -fx-border-radius: 8; -fx-border-color: #ddd;
                                              -fx-border-width: 1; -fx-padding: 8 12;" />
                        </VBox>
                        <VBox spacing="6" GridPane.columnIndex="1">
                            <HBox spacing="2">
                                <Label style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #555;"
                                       text="Thời gian kết thúc" />
                                <Label style="-fx-font-size: 12; -fx-text-fill: #E24B4A;" text="*" />
                            </HBox>
                            <TextField fx:id="fieldThoiGianKetThuc"
                                       promptText="dd/MM/yyyy HH:mm"
                                       style="-fx-font-size: 13; -fx-background-radius: 8;
                                              -fx-border-radius: 8; -fx-border-color: #ddd;
                                              -fx-border-width: 1; -fx-padding: 8 12;" />
                        </VBox>
                    </GridPane>

                    <!-- Giá -->
                    <GridPane hgap="16">
                        <columnConstraints>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="50" />
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="50" />
                        </columnConstraints>
                        <VBox spacing="6" GridPane.columnIndex="0">
                            <HBox spacing="2">
                                <Label style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #555;"
                                       text="Giá khởi điểm (€)" />
                                <Label style="-fx-font-size: 12; -fx-text-fill: #E24B4A;" text="*" />
                            </HBox>
                            <HBox>
                                <Label style="-fx-background-color: #f5f5f5; -fx-text-fill: #888;
                                              -fx-font-size: 13; -fx-padding: 8 10;
                                              -fx-border-color: #ddd; -fx-border-width: 1 0 1 1;
                                              -fx-border-radius: 0; -fx-background-radius: 0;"
                                       text="€" />
                                <TextField fx:id="fieldGiaKhoiDiem"
                                           promptText="0"
                                           HBox.hgrow="ALWAYS"
                                           style="-fx-font-size: 13; -fx-background-radius: 0 8 8 0;
                                                  -fx-border-radius: 0 8 8 0; -fx-border-color: #ddd;
                                                  -fx-border-width: 1; -fx-padding: 8 12;" />
                            </HBox>
                            <Label style="-fx-font-size: 11; -fx-text-fill: #aaa;"
                                   text="Giá tối thiểu để bắt đầu đấu giá" />
                        </VBox>
                        <VBox spacing="6" GridPane.columnIndex="1">
                            <Label style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #555;"
                                   text="Bước giá tối thiểu (€)" />
                            <HBox>
                                <Label style="-fx-background-color: #f5f5f5; -fx-text-fill: #888;
                                              -fx-font-size: 13; -fx-padding: 8 10;
                                              -fx-border-color: #ddd; -fx-border-width: 1 0 1 1;
                                              -fx-border-radius: 0; -fx-background-radius: 0;"
                                       text="€" />
                                <TextField fx:id="fieldBuocGia"
                                           promptText="50"
                                           HBox.hgrow="ALWAYS"
                                           style="-fx-font-size: 13; -fx-background-radius: 0 8 8 0;
                                                  -fx-border-radius: 0 8 8 0; -fx-border-color: #ddd;
                                                  -fx-border-width: 1; -fx-padding: 8 12;" />
                            </HBox>
                            <Label style="-fx-font-size: 11; -fx-text-fill: #aaa;"
                                   text="Mỗi lần trả giá phải tăng thêm ít nhất" />
                        </VBox>
                    </GridPane>
                </VBox>

                <!-- Label lỗi -->
                <Label fx:id="lblError"
                       managed="false" visible="false"
                       style="-fx-text-fill: #E24B4A; -fx-font-size: 13;"
                       text="" />

                <!-- Action buttons -->
                <HBox alignment="CENTER_RIGHT" spacing="12">
                    <Button fx:id="btnHuy" onAction="#handleHuy"
                            style="-fx-background-color: transparent; -fx-text-fill: #666;
                                   -fx-border-color: #ccc; -fx-border-width: 1;
                                   -fx-border-radius: 8; -fx-background-radius: 8;
                                   -fx-font-size: 13; -fx-padding: 9 20; -fx-cursor: hand;"
                            text="Hủy" />
                    <Button fx:id="btnTiepTheo" onAction="#handleTiepTheo"
                            style="-fx-background-color: #1A2744; -fx-text-fill: #C9A84C;
                                   -fx-font-size: 13; -fx-font-weight: bold;
                                   -fx-background-radius: 8; -fx-padding: 9 24;
                                   -fx-cursor: hand; -fx-border-width: 0;"
                            text="Tiếp theo  ›" />
                </HBox>

            </VBox>
        </content>
    </ScrollPane>

</HBox>
