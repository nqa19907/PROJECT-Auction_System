<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<!-- ===== MAIN FORM ===== -->

<VBox maxHeight="1.7976931348623157E308" spacing="16" styleClass="profile-container" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="auction_system.client.controllers.components.ProfileController">
   <VBox spacing="8.0">
      <children>
               <Label styleClass="profile-section-title" text="Thông tin cá nhân" />
         <VBox>
            <children>
               <HBox spacing="15.0">
                  <children>
                     <StackPane>
                        <children>
                           <Circle radius="40" styleClass="profile-avatar-circle" />
                           <Region>
                              <styleClass>
                                 <String fx:value="icon-bidder" />
                                 <String fx:value="avatar-icon" />
                              </styleClass>
                           </Region>
                        </children>
                     </StackPane>
                     <VBox spacing="4.0">
                        <children>
                           <Label fx:id="lblUsername" prefWidth="140.0" styleClass="profile-username" text="Phạm Nhật Vượng Vin" wrapText="true">
                              <VBox.margin>
                                 <Insets />
                              </VBox.margin>
                           </Label>
                           <Region VBox.vgrow="ALWAYS" />
                           <Label fx:id="lblEmail" styleClass="profile-email" text="template@gmail.com">
                              <VBox.margin>
                                 <Insets />
                              </VBox.margin>
                           </Label>
                           <Region VBox.vgrow="ALWAYS" />
                           <HBox maxHeight="-Infinity" maxWidth="-Infinity" styleClass="badge">
                              <children>
                                 <Label fx:id="lblRole" text="Người đấu giá" />
                              </children>
                           </HBox>
                        </children>
                     </VBox>
                  </children>
               </HBox>
            </children>
         </VBox>
      </children>
   </VBox>
   <Region fx:id="profileDivider" prefHeight="200.0" prefWidth="200.0" styleClass="profile-divider-line" />
   <VBox fx:id="walletSection" spacing="8.0">
      <children>
               <Label styleClass="profile-section-title" text="Ví" />
         <VBox spacing="16.0">
            <children>
               <VBox>
                  <children>
                     <VBox>
                        <children>
                           <Label styleClass="field-label" text="Số dư tài khoản" />
                           <HBox alignment="BASELINE_LEFT">
                              <children>
                                 <Label fx:id="lblBalance" styleClass="metric-value" text="69420" />
                                 <Label styleClass="metric-unit" text="VNĐ" />
                              </children>
                           </HBox>
                        </children>
                     </VBox>
                  </children>
               </VBox>
               <VBox spacing="8.0">
                  <children>
                     <Label styleClass="field-label" text="Nạp tiền vào tài khoản (VNĐ)" />
                     <HBox spacing="6.0">
                        <children>
                           <TextField fx:id="fieldDeposit" promptText="Ví dụ: 500000" styleClass="input-field" />
                                <Button fx:id="btnDeposit" maxHeight="1.7976931348623157E308" onAction="#handleDeposit" styleClass="btn-deposit" text="Nạp tiền" />
                        </children>
                     </HBox>
                  </children>
               </VBox>
            </children>
         </VBox>
      </children>
   </VBox>

             <!-- Action buttons -->
       <HBox alignment="CENTER_RIGHT" spacing="12" />
   <stylesheets>
      <URL value="@../../css/buttons.css" />
      <URL value="@../../css/global.css" />
      <URL value="@../../css/icons.css" />
      <URL value="@../../css/images.css" />
      <URL value="@../../css/inputs.css" />
      <URL value="@../../css/layout.css" />
      <URL value="@../../css/typography.css" />
      <URL value="@../../css/variables.css" />
   </stylesheets>

         </VBox>
