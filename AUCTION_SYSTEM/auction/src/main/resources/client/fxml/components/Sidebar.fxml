<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import auction_system.client.components.SvgIcon?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox id="categorySidebar" fx:id="categorySidebar" styleClass="category-sidebar" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="auction_system.client.controllers.components.SidebarController">
    <children>
        <Label styleClass="text-header-secondary" text="DANH MỤC SẢN PHẨM">
            <VBox.margin>
                <Insets bottom="8.0" top="16.0" />
            </VBox.margin>
        </Label>
        <HBox id="categoryAll" alignment="CENTER_LEFT" onMouseClicked="#handleCategoryFilter" spacing="15.0" styleClass="category-option">
            <children>
                <SvgIcon icon="category" styleClass="sidebar-icon" />
                <Label styleClass="text-body" text="Tất cả" />
            </children>
        </HBox>
        <HBox id="categoryArt" alignment="CENTER_LEFT" onMouseClicked="#handleCategoryFilter" spacing="15.0" styleClass="category-option">
            <children>
                <SvgIcon icon="art" styleClass="sidebar-icon" />
                <Label styleClass="text-body" text="Nghệ thuật" />
            </children>
        </HBox>
        <HBox id="categoryElectronic" alignment="CENTER_LEFT" onMouseClicked="#handleCategoryFilter" spacing="15.0" styleClass="category-option">
            <children>
                <SvgIcon icon="electronic" styleClass="sidebar-icon" />
                <Label styleClass="text-body" text="Đồ điện tử" />
            </children>
        </HBox>
        <HBox id="categoryVehicle" alignment="CENTER_LEFT" onMouseClicked="#handleCategoryFilter" spacing="15.0" styleClass="category-option">
            <children>
                <SvgIcon icon="vehicle" styleClass="sidebar-icon" />
                <Label styleClass="text-body" text="Phương tiện giao thông" />
            </children>
        </HBox>
        <Region styleClass="sidebar-divider">
            <VBox.margin>
                <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
            </VBox.margin>
        </Region>
        <HBox id="publishItem" fx:id="publishItem" alignment="CENTER_LEFT" onMouseClicked="#handlePublishItem" spacing="15.0" styleClass="category-option">
            <children>
                <SvgIcon icon="add" styleClass="sidebar-icon" />
                <Label styleClass="text-body" text="Đăng bán" />
            </children>
        </HBox>

        <!-- Mục mới cho user quản lý các phiên đấu giá đã đăng -->
        <HBox id="myAuctionManagement" fx:id="myAuctionManagement" alignment="CENTER_LEFT" onMouseClicked="#handleMyAuctionManagement" spacing="15.0" styleClass="category-option">
            <children>
                <SvgIcon icon="format-list-bulleted" styleClass="sidebar-icon" />
                <Label styleClass="text-body" text="Quản lý phiên của tôi" />
            </children>
        </HBox>

        <HBox id="testAdminView" fx:id="testAdminView" alignment="CENTER_LEFT" onMouseClicked="#loadAdminView" spacing="15.0" styleClass="category-option">
            <children>
                <SvgIcon icon="add" styleClass="sidebar-icon" />
                <Label styleClass="text-body" text="Thử màn hình admin" />
            </children>
        </HBox>

    </children>
   <stylesheets>
      <URL value="@../../css/buttons.css" />
      <URL value="@../../css/global.css" />
      <URL value="@../../css/icons.css" />
      <URL value="@../../css/images.css" />
      <URL value="@../../css/inputs.css" />
      <URL value="@../../css/layout.css" />
      <URL value="@../../css/typography.css" />
      <URL value="@../../css/variables.css" />
   </stylesheets>
</VBox>
