<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<StackPane prefHeight="700.0"
           prefWidth="900.0"
           styleClass="login-background"
           stylesheets="@../../css/global.css"
           xmlns="http://javafx.com/javafx/26"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="auction_system.client.controllers.auth.RegisterController">

    <Circle fill="#c8872a"
            opacity="0.07"
            radius="200"
            translateX="230"
            translateY="-270" />

    <Circle fill="#c8872a"
            opacity="0.05"
            radius="160"
            translateX="-310"
            translateY="250" />

    <VBox alignment="CENTER"
          maxHeight="-Infinity"
          maxWidth="400.0"
          spacing="8.0"
          styleClass="login-card">

        <HBox alignment="CENTER"
              spacing="10"
              styleClass="font-icon">
            <Region prefHeight="50.0"
                    prefWidth="50.0"
                    styleClass="icon-gavel" />
            <Label styleClass="text-header"
                   text="AuctionHub" />
        </HBox>

        <Label styleClass="text-header-secondary"
               text="Tạo tài khoản để bắt đầu đấu giá">
            <VBox.margin>
                <Insets bottom="10.0" top="10.0" />
            </VBox.margin>
        </Label>

        <VBox spacing="11.0">
            <VBox spacing="3.0">
                <Label maxWidth="Infinity"
                       styleClass="text-label-code"
                       text="TÊN NGƯỜI DÙNG" />

                <TextField fx:id="nameField"
                           onAction="#handleNameEnter"
                           promptText="Tên người dùng"
                           styleClass="input-field" />
            </VBox>

            <VBox spacing="3.0">
                <Label maxWidth="Infinity"
                       styleClass="text-label-code"
                       text="EMAIL" />

                <TextField fx:id="emailField"
                           onAction="#handleEmailEnter"
                           promptText="ten@example.com"
                           styleClass="input-field" />
            </VBox>

            <VBox spacing="3.0">
                <Label maxWidth="Infinity"
                       styleClass="text-label-code"
                       text="MẬT KHẨU" />

                <PasswordField fx:id="passwordField"
                               onAction="#handleRegister"
                               promptText="Ít nhất 6 ký tự"
                               styleClass="input-field" />
            </VBox>
        </VBox>

        <Label fx:id="errorLabel"
               managed="false"
               visible="false"
               wrapText="true"
               styleClass="text-error" />

        <Button maxWidth="1.7976931348623157E308"
                onAction="#handleRegister"
                styleClass="btn-primary"
                text="Đăng ký">
            <VBox.margin>
                <Insets top="8.0" />
            </VBox.margin>
        </Button>

        <HBox alignment="CENTER" spacing="10">
            <VBox.margin>
                <Insets />
            </VBox.margin>

            <Region styleClass="divider-line"
                    HBox.hgrow="ALWAYS" />

            <Label minWidth="-Infinity"
                   styleClass="text-primary"
                   text="hoặc" />

            <Region styleClass="divider-line"
                    HBox.hgrow="ALWAYS" />

            <padding>
                <Insets bottom="10.0"
                        left="10.0"
                        right="10.0"
                        top="10.0" />
            </padding>
        </HBox>

        <Button maxWidth="1.7976931348623157E308"
                onAction="#handleGoToLogin"
                styleClass="btn-secondary"
                text="Quay lại đăng nhập" />

        <StackPane.margin>
            <Insets bottom="20.0"
                    left="20.0"
                    right="20.0"
                    top="20.0" />
        </StackPane.margin>
    </VBox>
</StackPane>