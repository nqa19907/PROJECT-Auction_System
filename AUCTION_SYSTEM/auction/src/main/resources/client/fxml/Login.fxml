<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml/1"
           prefWidth="360" prefHeight="720"
           style="-fx-background-color: #1565C0;">

    <!-- Bong bóng trang trí phía trên -->
    <VBox alignment="TOP_LEFT" spacing="0">
        <StackPane prefHeight="280">
            <Circle radius="70" style="-fx-fill: #1976D2;" translateX="-50" translateY="-20"/>
            <Circle radius="35" style="-fx-fill: #1976D2;" translateX="120" translateY="-60"/>
            <Circle radius="25" style="-fx-fill: #0D47A1;" translateX="80" translateY="30"/>
            <Circle radius="50" style="-fx-fill: #0D47A1;" translateX="-110" translateY="80"/>

            <!-- Title Welcome Back -->
            <VBox alignment="BOTTOM_LEFT" style="-fx-padding: 0 0 20 30;">
                <Label text="Welcome" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="Back" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: white;"/>
            </VBox>
        </StackPane>
    </VBox>

    <!-- Phần trắng phía dưới -->
    <VBox alignment="BOTTOM_CENTER">
        <VBox alignment="CENTER" spacing="14"
              style="-fx-background-color: white; -fx-background-radius: 30 30 0 0; -fx-padding: 40 30 40 30;">

            <!-- Email field -->
            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-background-color: #f5f5f5; -fx-background-radius: 10; -fx-padding: 12 16;">
                <Label text="✉" style="-fx-font-size: 14; -fx-text-fill: #999;"/>
                <TextField promptText="water@gmail.com"
                           style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-font-size: 13;"
                           prefWidth="240" HBox.hgrow="ALWAYS"/>
                <Label text="✓" style="-fx-font-size: 14; -fx-text-fill: #00b67a;"/>
            </HBox>

            <!-- Password field -->
            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-background-color: #f5f5f5; -fx-background-radius: 10; -fx-padding: 12 16;">
                <Label text="🔒" style="-fx-font-size: 14; -fx-text-fill: #999;"/>
                <PasswordField promptText="Password"
                               style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-font-size: 13;"
                               prefWidth="240" HBox.hgrow="ALWAYS"/>
            </HBox>

            <!-- Forgot password -->
            <HBox alignment="CENTER_RIGHT" prefWidth="280">
                <Hyperlink text="Forgot password?"
                           style="-fx-font-size: 12; -fx-text-fill: #1565C0;"/>
            </HBox>

            <!-- Nút Log In -->
            <Button text="Log In"
                    prefWidth="280" prefHeight="45"
                    style="-fx-background-color: #1565C0; -fx-text-fill: white; -fx-font-size: 15; -fx-background-radius: 25; -fx-cursor: hand;"/>

            <!-- Hoặc -->
            <Label text="or" style="-fx-font-size: 12; -fx-text-fill: #999;"/>

            <!-- Nút Sign Up -->
            <Button text="Sign up"
                    prefWidth="280" prefHeight="45"
                    style="-fx-background-color: transparent; -fx-text-fill: #1565C0; -fx-font-size: 15; -fx-background-radius: 25; -fx-border-color: #1565C0; -fx-border-radius: 25; -fx-cursor: hand;"/>

        </VBox>
    </VBox>

</StackPane>