<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import java.net.URL?>
<BorderPane xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:id="root"
            fx:controller="auction_system.client.controllers.auction.AdminDashboardController"
            prefWidth="1280"
            prefHeight="720"
            styleClass="admin-root">


    <!-- Sidebar bên trái -->
    <left>
        <VBox prefWidth="250" spacing="12" styleClass="admin-sidebar">
            <padding>
                <Insets top="24" right="16" bottom="24" left="16"/>
            </padding>

            <Label text="AuctionHub" styleClass="brand-title"/>
            <Label text="ADMIN PANEL" styleClass="sidebar-section-title"/>

            <Button fx:id="btnOverview" text="Tổng quan" styleClass="sidebar-button"/>
            <Button fx:id="btnManageUsers" text="Quản lý người dùng" styleClass="sidebar-button"/>
            <Button fx:id="btnManageAuctions" text="Quản lý phiên đấu giá" styleClass="sidebar-button"/>
            <Button fx:id="btnManageProducts" text="Duyệt sản phẩm" styleClass="sidebar-button"/>
            <Button fx:id="btnTransactions" text="Giao dịch" styleClass="sidebar-button"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Button fx:id="btnBackToClient" text="Về màn hình chính" styleClass="outline-button"/>
            <Button fx:id="btnLogout" text="Đăng xuất" styleClass="danger-button"/>
        </VBox>
    </left>

    <!-- Header trên cùng -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16" styleClass="admin-header">
            <padding>
                <Insets top="18" right="28" bottom="18" left="28"/>
            </padding>

            <Label text="Admin Dashboard" styleClass="page-title"/>

            <Region HBox.hgrow="ALWAYS"/>

            <TextField fx:id="txtSearch"
                       promptText="Tìm user, sản phẩm, phiên đấu giá..."
                       prefWidth="360"
                       styleClass="search-box"/>

            <Label fx:id="lblAdminName" text="Admin" styleClass="admin-name"/>
        </HBox>
    </top>

    <!-- Nội dung chính -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="content-scroll">
            <VBox spacing="24" styleClass="admin-content">
                <padding>
                    <Insets top="28" right="32" bottom="32" left="32"/>
                </padding>

                <!-- Thẻ thống kê -->
                <HBox spacing="18">
                    <VBox styleClass="stat-card">
                        <Label text="Tổng người dùng" styleClass="stat-label"/>
                        <Label fx:id="lblTotalUsers" text="128" styleClass="stat-value"/>
                    </VBox>

                    <VBox styleClass="stat-card">
                        <Label text="Phiên đang chạy" styleClass="stat-label"/>
                        <Label fx:id="lblActiveAuctions" text="24" styleClass="stat-value"/>
                    </VBox>

                    <VBox styleClass="stat-card">
                        <Label text="Giao dịch hôm nay" styleClass="stat-label"/>
                        <Label fx:id="lblTodayTransactions" text="56" styleClass="stat-value"/>
                    </VBox>

                    <VBox styleClass="stat-card">
                        <Label text="Tài khoản bị ban" styleClass="stat-label"/>
                        <Label fx:id="lblBannedUsers" text="5" styleClass="stat-value danger-text"/>
                    </VBox>
                </HBox>

                <!-- Quản lý người dùng -->
                <VBox spacing="12" styleClass="panel">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Quản lý người dùng" styleClass="panel-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="btnRefreshUsers" text="Làm mới" styleClass="small-button"/>
                    </HBox>

                    <TableView fx:id="tblUsers" prefHeight="220" styleClass="admin-table">
                        <columns>
                            <TableColumn fx:id="colUserId" text="ID" prefWidth="80"/>
                            <TableColumn fx:id="colUsername" text="Tên người dùng" prefWidth="180"/>
                            <TableColumn fx:id="colEmail" text="Email" prefWidth="240"/>
                            <TableColumn fx:id="colBalance" text="Số dư" prefWidth="130"/>
                            <TableColumn fx:id="colUserStatus" text="Trạng thái" prefWidth="130"/>
                            <TableColumn fx:id="colUserAction" text="Thao tác" prefWidth="160"/>
                        </columns>
                    </TableView>
                </VBox>

                <!-- Quản lý phiên đấu giá -->
                <VBox spacing="12" styleClass="panel">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Quản lý phiên đấu giá" styleClass="panel-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="btnCloseAuction" text="Đóng auction" styleClass="warning-button"/>
                    </HBox>

                    <TableView fx:id="tblAuctions" prefHeight="220" styleClass="admin-table">
                        <columns>
                            <TableColumn fx:id="colAuctionId" text="ID" prefWidth="80"/>
                            <TableColumn fx:id="colProductName" text="Sản phẩm" prefWidth="220"/>
                            <TableColumn fx:id="colSeller" text="Người bán" prefWidth="160"/>
                            <TableColumn fx:id="colCurrentPrice" text="Giá hiện tại" prefWidth="150"/>
                            <TableColumn fx:id="colAuctionStatus" text="Trạng thái" prefWidth="130"/>
                            <TableColumn fx:id="colAuctionAction" text="Thao tác" prefWidth="160"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

    <stylesheets>
        <URL value="@../../css/admin-dashboard.css" />
    </stylesheets>

</BorderPane>