<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="root"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="auction_system.client.controllers.auction.AdminDashboardController"
            styleClass="admin-root">

    <top>
        <!-- Header 2 hàng: thương hiệu + thống kê -->
        <VBox spacing="12" styleClass="admin-header">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="16" styleClass="header-main-row">
                    <children>
                        <VBox spacing="2">
                            <children>
                                <Label text="AuctionHub" styleClass="brand-title"/>
                                <Label text="Bảng điều khiển quản trị" styleClass="brand-subtitle"/>
                            </children>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Label text="Admin" styleClass="admin-badge"/>
                        <Button fx:id="btnBack" onAction="#handleBack" text="Quay về" styleClass="header-action-button"/>
                    </children>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="header-stats-row">
                    <children>
                        <Label text="128 người dùng" styleClass="stat-chip"/>
                        <Label text="24 phiên đang chạy" styleClass="stat-chip"/>
                        <Label text="5 bị ban" styleClass="stat-chip alert"/>
                    </children>
                </HBox>
            </children>
            <padding>
                <Insets top="16" right="34" bottom="16" left="34"/>
            </padding>
        </VBox>
    </top>

    <center>
        <HBox spacing="24" styleClass="content-wrap">
            <padding>
                <Insets top="28" right="34" bottom="30" left="34"/>
            </padding>

            <children>
                <VBox spacing="16" styleClass="panel" HBox.hgrow="ALWAYS">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="14">
                            <children>
                                <Label text="👤" styleClass="panel-icon"/>

                                <Label text="Quản lý người dùng"
                                       styleClass="panel-title"
                                       minWidth="230"
                                       maxWidth="Infinity"/>

                                <Region HBox.hgrow="ALWAYS"/>

                                <TextField fx:id="txtSearchUser"
                                           promptText="Tìm người dùng..."
                                           styleClass="search-field"/>
                                <Button fx:id="btnRefreshUsers"
                                        text="↻"
                                        styleClass="circle-button"/>
                            </children>
                        </HBox>

                        <TableView fx:id="tblUsers" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colUserId" text="ID" prefWidth="70"/>
                                <TableColumn fx:id="colUsername" text="Tên" prefWidth="170"/>
                                <TableColumn fx:id="colEmail" text="Email" prefWidth="240"/>
                                <TableColumn fx:id="colUserStatus" text="Trạng thái" prefWidth="120"/>
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                        </TableView>

                        <HBox alignment="CENTER_RIGHT">
                            <children>
                                <Button fx:id="btnDeleteUser"
                                        text="🗑  Xoá người dùng"
                                        styleClass="danger-button"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <VBox spacing="16" styleClass="panel" HBox.hgrow="ALWAYS">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="14">
                            <children>
                                <Label text="🔨" styleClass="panel-icon"/>
                                <Label text="Phiên đấu giá" styleClass="panel-title"/>

                                <Region HBox.hgrow="ALWAYS"/>

                                <TextField fx:id="txtSearchAuction"
                                           promptText="Tìm phiên..."
                                           styleClass="search-field"/>
                                <Button fx:id="btnRefreshAuctions"
                                        text="↻"
                                        styleClass="circle-button"/>
                            </children>
                        </HBox>

                        <TableView fx:id="tblAuctions" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colAuctionId" text="ID" prefWidth="70"/>
                                <TableColumn fx:id="colProductName" text="Sản phẩm" prefWidth="230"/>
                                <TableColumn fx:id="colSeller" text="Người bán" prefWidth="150"/>
                                <TableColumn fx:id="colCurrentPrice" text="Giá hiện tại" prefWidth="140"/>
                                <TableColumn fx:id="colAuctionStatus" text="Trạng thái" prefWidth="120"/>
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                        </TableView>

                        <HBox alignment="CENTER_RIGHT">
                            <children>
                                <Button fx:id="btnDeleteAuction"
                                        text="🗑  Xoá phiên"
                                        styleClass="danger-button"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </HBox>
    </center>

    <stylesheets>
        <URL value="@../../css/global.css"/>
        <URL value="@../../css/admin-dashboard.css"/>
    </stylesheets>

</BorderPane>
