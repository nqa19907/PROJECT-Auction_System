<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true"
            hbarPolicy="NEVER"
            style="-fx-background-color: #F7F4EF; -fx-background: #F7F4EF;"
            vbarPolicy="AS_NEEDED"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1">

    <content>
        <VBox style="-fx-background-color: #F7F4EF;">
            <children>

                <StackPane fx:id="heroSliderContainer" prefHeight="350.0" prefWidth="1200.0">
                    <children>
                        <StackPane fx:id="heroSlider">
                            <children>
                                <ImageView fx:id="sliderImage"
                                           fitHeight="350.0"
                                           fitWidth="1200.0"
                                           pickOnBounds="true"
                                           preserveRatio="false">
                                    <image>
                                        <Image url="@/client/images/banner.jpg" />
                                    </image>
                                </ImageView>

                                <Pane style="-fx-background-color: linear-gradient(to right, rgba(0,0,0,0.6), transparent, rgba(0,0,0,0.6));" />
                            </children>
                        </StackPane>

                        <HBox mouseTransparent="true" prefHeight="350.0" prefWidth="1200.0">
                            <children>
                                <ImageView fitHeight="350.0"
                                           fitWidth="50.0"
                                           pickOnBounds="true"
                                           preserveRatio="false">
                                    <image>
                                        <!-- ảnh cố định trái -->
                                    </image>
                                </ImageView>

                                <Region HBox.hgrow="ALWAYS" />

                                <ImageView fitHeight="350.0"
                                           fitWidth="50.0"
                                           pickOnBounds="true"
                                           preserveRatio="false">
                                    <image>
                                        <!-- ảnh cố định phải -->
                                    </image>
                                </ImageView>
                            </children>
                        </HBox>

                        <VBox alignment="CENTER_LEFT" mouseTransparent="false" spacing="20">
                            <padding>
                                <Insets left="350" />
                            </padding>

                            <children>
                                <Label style="-fx-text-fill: #C9A84C; -fx-font-weight: bold;"
                                       text="SỰ KIỆN ĐẶC BIỆT" />

                                <Label style="-fx-font-size: 36; -fx-text-fill: white; -fx-font-weight: bold;"
                                       text="Tuần Lễ Vàng&#10;Đấu Giá Sang" />

                                <Button style="-fx-background-color: #C9A84C; -fx-padding: 10 30; -fx-cursor: hand;"
                                        text="XEM NGAY" />
                            </children>
                        </VBox>
                    </children>
                </StackPane>

                <!-- Phần trên là slide quảng cáo -->

                <VBox style="-fx-background-color: #F7F4EF;">
                    <HBox spacing="20.0" style="-fx-padding: 20;">
                        <children>

                            <VBox spacing="16" style="-fx-background-color: #F7F4EF; -fx-padding: 30 40 20 40;">

                                <Label style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #1A2744;"
                                       text="Tài sản nổi bật" />

                                <HBox spacing="20">

                                    <!-- Card 1 -->
                                    <VBox alignment="CENTER"
                                          prefHeight="220"
                                          prefWidth="280"
                                          spacing="12"
                                          style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #e8e8e8; -fx-border-radius: 16; -fx-border-width: 1; -fx-padding: 30 24 24 24;">
                                        <Label alignment="CENTER"
                                               style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #1A2744;"
                                               text="Đồng hồ Rolex Submariner Date 2004"
                                               wrapText="true" />

                                        <Label style="-fx-font-size: 13; -fx-text-fill: #888;"
                                               text="Giá hiện tại: €15,500" />

                                        <Button style="-fx-background-color: #8B5E52; -fx-text-fill: white; -fx-font-size: 13; -fx-background-radius: 30; -fx-padding: 10 28; -fx-cursor: hand; -fx-border-width: 0;"
                                                text="Đấu giá ngay" />
                                    </VBox>

                                    <!-- Card 2 -->
                                    <VBox alignment="CENTER"
                                          prefHeight="220"
                                          prefWidth="280"
                                          spacing="12"
                                          style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #e8e8e8; -fx-border-radius: 16; -fx-border-width: 1; -fx-padding: 30 24 24 24;">
                                        <Label alignment="CENTER"
                                               style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #1A2744;"
                                               text="Tượng đồng chiến binh Hy Lạp cổ đại"
                                               wrapText="true" />

                                        <Label style="-fx-font-size: 13; -fx-text-fill: #888;"
                                               text="Giá hiện tại: €3,200" />

                                        <Button style="-fx-background-color: #8B5E52; -fx-text-fill: white; -fx-font-size: 13; -fx-background-radius: 30; -fx-padding: 10 28; -fx-cursor: hand; -fx-border-width: 0;"
                                                text="Đấu giá ngay" />
                                    </VBox>

                                    <!-- Card 3 -->
                                    <VBox alignment="CENTER"
                                          prefHeight="220"
                                          prefWidth="280"
                                          spacing="12"
                                          style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #e8e8e8; -fx-border-radius: 16; -fx-border-width: 1; -fx-padding: 30 24 24 24;">
                                        <Label alignment="CENTER"
                                               style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #1A2744;"
                                               text="Bộ xu bạc La Mã thế kỷ 18 nguyên bản"
                                               wrapText="true" />

                                        <Label style="-fx-font-size: 13; -fx-text-fill: #888;"
                                               text="Giá hiện tại: €850" />

                                        <Button style="-fx-background-color: #8B5E52; -fx-text-fill: white; -fx-font-size: 13; -fx-background-radius: 30; -fx-padding: 10 28; -fx-cursor: hand; -fx-border-width: 0;"
                                                text="Đấu giá ngay" />
                                    </VBox>

                                    <!-- Card 4 -->
                                    <VBox alignment="CENTER"
                                          prefHeight="220"
                                          prefWidth="280"
                                          spacing="12"
                                          style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #e8e8e8; -fx-border-radius: 16; -fx-border-width: 1; -fx-padding: 30 24 24 24;">
                                        <Label alignment="CENTER"
                                               style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #1A2744;"
                                               text="Tranh sơn dầu trừu tượng hiện đại"
                                               wrapText="true" />

                                        <Label style="-fx-font-size: 13; -fx-text-fill: #888;"
                                               text="Giá hiện tại: €1,400" />

                                        <Button style="-fx-background-color: #8B5E52; -fx-text-fill: white; -fx-font-size: 13; -fx-background-radius: 30; -fx-padding: 10 28; -fx-cursor: hand; -fx-border-width: 0;"
                                                text="Đấu giá ngay" />
                                    </VBox>

                                </HBox>
                            </VBox>

                        </children>
                    </HBox>

                    <VBox style="-fx-background-color: #0F1B35;">

                        <!-- Phần review giữ nguyên -->
                        <VBox alignment="CENTER"
                              spacing="30.0"
                              style="-fx-background-color: #F2EDE4; -fx-padding: 50 20 50 20;">
                            <Label style="-fx-font-size: 24px; -fx-font-weight: bold;"
                                   text="Khách hàng nói gì về chúng tôi?" />

                            <HBox alignment="CENTER" spacing="10.0">
                                <Button fx:id="btnScrollLeft"
                                        style="-fx-background-radius: 50; -fx-cursor: hand;"
                                        text="&lt;" />

                                <ScrollPane fx:id="reviewScrollPane"
                                            hbarPolicy="NEVER"
                                            prefHeight="160.0"
                                            prefWidth="850.0"
                                            style="-fx-background-color: transparent; -fx-background: transparent;"
                                            vbarPolicy="NEVER">
                                    <content>
                                        <HBox fx:id="reviewContainer"
                                              spacing="20.0"
                                              style="-fx-padding: 10;" />
                                    </content>
                                </ScrollPane>

                                <Button fx:id="btnScrollRight"
                                        style="-fx-background-radius: 50; -fx-cursor: hand;"
                                        text="&gt;" />
                            </HBox>
                        </VBox>

                        <!-- FOOTER CHÍNH -->
                        <HBox spacing="40"
                              style="-fx-background-color: #1A2744; -fx-padding: 40 60 40 60;">

                            <!-- Cột 1 -->
                            <VBox maxWidth="260" spacing="10" HBox.hgrow="ALWAYS">
                                <Label style="-fx-text-fill: #C9A84C; -fx-font-size: 16px; -fx-font-weight: bold;"
                                       text="Web Đấu Giá của 4 ae" />

                                <Label style="-fx-text-fill: #aaaaaa; -fx-font-size: 13px;"
                                       text="Đồ án môn Lập trình Java" />

                                <Label style="-fx-text-fill: #cccccc; -fx-font-size: 13px;"
                                       text="Thành viên 1: Phương" />

                                <Label style="-fx-text-fill: #cccccc; -fx-font-size: 13px;"
                                       text="Thành viên 2: [Tên]" />

                                <Label style="-fx-text-fill: #cccccc; -fx-font-size: 13px;"
                                       text="Thành viên 3: [Tên]" />

                                <Label style="-fx-text-fill: #cccccc; -fx-font-size: 13px;"
                                       text="Thành viên 4: [Tên]" />
                            </VBox>

                            <!-- Cột 2 -->
                            <VBox spacing="14" HBox.hgrow="ALWAYS">
                                <Label style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"
                                       text="Về chúng tôi" />

                                <Label style="-fx-text-fill: #cccccc; -fx-font-size: 13px; -fx-cursor: hand;"
                                       text="Giới thiệu" />

                                <Label style="-fx-text-fill: #cccccc; -fx-font-size: 13px; -fx-cursor: hand;"
                                       text="Quy chế hoạt động" />

                                <Label style="-fx-text-fill: #cccccc; -fx-font-size: 13px; -fx-cursor: hand;"
                                       text="Hướng dẫn sử dụng" />
                            </VBox>

                            <!-- Cột 3 -->
                            <VBox spacing="14" HBox.hgrow="ALWAYS">
                                <Label style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"
                                       text="Hỗ trợ khách hàng" />

                                <Label style="-fx-text-fill: #cccccc; -fx-font-size: 13px; -fx-cursor: hand;"
                                       text="Làm sao để đấu giá?" />

                                <Label style="-fx-text-fill: #cccccc; -fx-font-size: 13px; -fx-cursor: hand;"
                                       text="Chính sách bảo mật" />

                                <Label style="-fx-text-fill: #cccccc; -fx-font-size: 13px; -fx-cursor: hand;"
                                       text="Quy định người bán" />
                            </VBox>

                            <!-- Cột 4 -->
                            <VBox maxWidth="280" spacing="14" HBox.hgrow="ALWAYS">
                                <Label style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"
                                       text="Liên hệ" />

                                <Label style="-fx-text-fill: #cccccc; -fx-font-size: 13px;"
                                       text="Email: nhom4@university.edu.vn" />

                                <Label style="-fx-text-fill: #cccccc; -fx-font-size: 13px;"
                                       text="GitHub: github.com/phuong/auction-web" />

                                <Label style="-fx-text-fill: #aaaaaa; -fx-font-size: 13px;"
                                       text="Đăng ký nhận tin:" />

                                <HBox spacing="0"
                                      style="-fx-background-color: #2D3A5E; -fx-background-radius: 25; -fx-border-color: #C9A84C; -fx-border-radius: 25;">
                                    <TextField promptText="Nhập Email"
                                               style="-fx-background-color: transparent; -fx-text-fill: white; -fx-prompt-text-fill: #888; -fx-font-size: 13px; -fx-padding: 10 15 10 15; -fx-background-radius: 25 0 0 25; -fx-border-color: transparent;"
                                               HBox.hgrow="ALWAYS" />

                                    <Button style="-fx-background-color: #C9A84C; -fx-text-fill: #1A2744; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 0 25 25 0; -fx-padding: 10 20 10 20; -fx-cursor: hand; -fx-border-color: transparent;"
                                            text="Đăng ký" />
                                </HBox>
                            </VBox>

                        </HBox>

                        <!-- Đường kẻ -->
                        <HBox style="-fx-background-color: #2D3A5E; -fx-min-height: 1; -fx-pref-height: 1;" />

                        <!-- Copyright -->
                        <HBox alignment="CENTER_LEFT"
                              style="-fx-background-color: #0F1B35; -fx-padding: 15 60 15 60;">
                            <HBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label style="-fx-text-fill: #aaaaaa; -fx-font-size: 13px;"
                                       text="Copyright 2025 © " />

                                <Label style="-fx-text-fill: #C9A84C; -fx-font-size: 13px;"
                                       text="Web Đấu Giá - Nhóm 4" />
                            </HBox>

                            <Label style="-fx-text-fill: #555555; -fx-font-size: 12px;"
                                   text="Đồ án Lập trình Java" />
                        </HBox>

                    </VBox>
                </VBox>

            </children>
        </VBox>
    </content>
</ScrollPane>