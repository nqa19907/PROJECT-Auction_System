<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="mainLayout" minWidth="960" styleClass="dashboard-background"
    xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="auction_system.client.controllers.DashboardController">
    <top>
        <VBox id="headerWrapper">

            <!-- ===== NAVBAR ===== -->
            <HBox id="navBar" alignment="CENTER_LEFT" minWidth="960" prefHeight="64" spacing="12"
                styleClass="nav-bar">

                <!-- Logo -->
                <HBox id="logoWrapper" alignment="CENTER_LEFT" spacing="8">
                    <Region prefHeight="200.0" prefWidth="200.0" styleClass="icon-gavel" />
                    <Label styleClass="text-header" text="AuctionHub" />
                </HBox>

                <!-- Search bar -->
                <HBox id="searchWrapper" alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308"
                    spacing="8" styleClass="search-box" HBox.hgrow="ALWAYS">
                    <Region maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="20.0"
                        prefWidth="20.0" styleClass="icon-search" />
                    <TextField fx:id="searchField" maxWidth="1.7976931348623157E308"
                        promptText="Search for brand, model, artist..." styleClass="search-input"
                        HBox.hgrow="ALWAYS" />
                </HBox>

                <!-- Right side -->
                <HBox id="actionButtonsWrapper" alignment="CENTER" minWidth="300" spacing="16">

                    <!-- Nút đăng bán  -->
                    <Button onAction="#handleDangBan" styleClass="btn-primary" text="+ Đăng bán" />

                    <!-- button sign in -->
                    <Button fx:id="btnSignIn" onAction="#handleSignIn" styleClass="btn-primary"
                        text="Sign in" />
                </HBox>

            </HBox>

        </VBox>
    </top>

    <center>

        <ScrollPane id="mainContentScroll" fitToWidth="true" hbarPolicy="NEVER"
            styleClass="main-content-area" vbarPolicy="AS_NEEDED">

            <content>
                <VBox id="scrollContentWrapper" styleClass="content-wrapper">
                    <children>
                        <HBox id="mainContentPadding" spacing="20.0">
                            <children>

                                <VBox id="featuredSection" spacing="16">

                                    <Label text="Tài sản nổi bật" />

                                    <HBox id="productCardsRow" spacing="20">

                                        <!-- Card 1 -->
                                        <VBox id="productCard1" alignment="CENTER" prefHeight="220"
                                            prefWidth="280" spacing="12" styleClass="product-card">
                                            <Region prefHeight="200.0" prefWidth="200.0"
                                                styleClass="img-product-rolex" />
                                            <Label alignment="CENTER"
                                                style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #1A2744;"
                                                text="Đồng hồ Rolex Submariner Date 2004"
                                                wrapText="true" />
                                            <Label style="-fx-font-size: 13; -fx-text-fill: #888;"
                                                text="Giá hiện tại: €15,500" />
                                            <Button styleClass="btn-bid" text="Đấu giá ngay" />
                                        </VBox>

                                        <!-- Card 2 -->
                                        <VBox id="productCard2" alignment="CENTER" prefHeight="220"
                                            prefWidth="280" spacing="12" styleClass="product-card">
                                            <Label alignment="CENTER"
                                                style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #1A2744;"
                                                text="Tượng đồng chiến binh Hy Lạp cổ đại"
                                                wrapText="true" />
                                            <Label style="-fx-font-size: 13; -fx-text-fill: #888;"
                                                text="Giá hiện tại: €3,200" />
                                            <Button styleClass="btn-bid" text="Đấu giá ngay" />
                                        </VBox>

                                        <!-- Card 3 -->
                                        <VBox id="productCard3" alignment="CENTER" prefHeight="220"
                                            prefWidth="280" spacing="12" styleClass="product-card">
                                            <Label alignment="CENTER"
                                                style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #1A2744;"
                                                text="Bộ xu bạc La Mã thế kỷ 18 nguyên bản"
                                                wrapText="true" />
                                            <Label style="-fx-font-size: 13; -fx-text-fill: #888;"
                                                text="Giá hiện tại: €850" />
                                            <Button styleClass="btn-bid" text="Đấu giá ngay" />
                                        </VBox>

                                        <!-- Card 4 -->
                                        <VBox id="productCard4" alignment="CENTER" prefHeight="220"
                                            prefWidth="280" spacing="12" styleClass="product-card">
                                            <Label alignment="CENTER"
                                                style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #1A2744;"
                                                text="Tranh sơn dầu trừu tượng hiện đại"
                                                wrapText="true" />
                                            <Label style="-fx-font-size: 13; -fx-text-fill: #888;"
                                                text="Giá hiện tại: €1,400" />
                                            <Button styleClass="btn-bid" text="Đấu giá ngay" />
                                        </VBox>

                                    </HBox>
                                </VBox>

                            </children>

                        </HBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
    <left>
        <VBox id="categorySidebar" styleClass="category-sidebar" BorderPane.alignment="CENTER">
            <children>
                <HBox id="categoryHome" alignment="CENTER_LEFT" spacing="15.0"
                    styleClass="category-option">
                    <children>
                        <Region styleClass="icon-home" />
                        <Label styleClass="text-body" text="Trang chủ" />
                    </children>
                </HBox>
                <Label styleClass="text-header-secondary" text="DANH MỤC SẢN PHẨM">
                    <VBox.margin>
                        <Insets bottom="8.0" top="16.0" />
                    </VBox.margin>
                </Label>
                <HBox id="categoryAll" alignment="CENTER_LEFT" spacing="15.0"
                    styleClass="category-option">
                    <children>
                        <Region styleClass="icon-category" />
                        <Label styleClass="text-body" text="Tất cả" />
                    </children>
                </HBox>
                <HBox id="categoryArt" alignment="CENTER_LEFT" spacing="15.0"
                    styleClass="category-option">
                    <children>
                        <Region styleClass="icon-art" />
                        <Label styleClass="text-body" text="Nghệ thuật" />
                    </children>
                </HBox>
                <HBox id="categoryElectronic" alignment="CENTER_LEFT" spacing="15.0"
                    styleClass="category-option">
                    <children>
                        <Region styleClass="icon-electronic" />
                        <Label styleClass="text-body" text="Đồ điện tử" />
                    </children>
                </HBox>
                <HBox id="categoryVehicle" alignment="CENTER_LEFT" spacing="15.0"
                    styleClass="category-option">
                    <children>
                        <Region styleClass="icon-vehicle" />
                        <Label styleClass="text-body" text="Phương tiện giao thông" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </left>
    <stylesheets>
        <URL value="@../css/global.css" />
        <URL value="@../css/inputs.css" />
        <URL value="@../css/variables.css" />
        <URL value="@../css/buttons.css" />
        <URL value="@../css/images.css" />
        <URL value="@../css/layout.css" />
        <URL value="@../css/typography.css" />
        <URL value="@../css/icons.css" />
    </stylesheets>

</BorderPane>